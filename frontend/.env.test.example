# Required for Playwright e2e tests against a Clerk test instance.
#
# 1. Create a dedicated Clerk *test* instance (separate from dev) with
#    password sign-in enabled and email/SMS verification disabled.
# 2. Create a single test user (no SSO) and put its credentials below.
# 3. Copy the test instance's publishable + secret keys here.
# 4. Run: VITE_CLERK_PUBLISHABLE_KEY=$CLERK_PUBLISHABLE_KEY pnpm test:e2e

CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# Frontend reads VITE_CLERK_PUBLISHABLE_KEY at dev-server boot. Mirror it so
# the spawned `pnpm dev` uses the test instance's frontend API.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx

E2E_TEST_USER_USERNAME=e2e+test@example.com
E2E_TEST_USER_PASSWORD=replace-me
